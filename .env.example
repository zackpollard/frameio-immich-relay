# Copy to .env and fill in.

# Frame.io V4 UUIDs (find with the discovery curl commands in the README,
# or from the URL bar in the Frame.io web UI).
FRAMEIO_ACCOUNT=00000000-0000-0000-0000-000000000000
FRAMEIO_WORKSPACE=00000000-0000-0000-0000-000000000000
FRAMEIO_FOLDER=00000000-0000-0000-0000-000000000000

# Publicly-reachable HTTPS URL that routes to this container's port 9000.
# Tailscale Funnel and Cloudflare Tunnel both work. Path must be /webhook.
FRAMEIO_PUBLIC_URL=https://<your-host>.<tailnet>.ts.net/webhook

# Immich target (optional). Leave both empty to skip Immich and keep
# downloads only on local disk. When set, the relay uploads each file
# to Immich, deletes the local copy on success, then deletes from Frame.io.
IMMICH_URL=https://immich.example.com
IMMICH_API_KEY=your-fine-grained-key-here

# Optional: delete abandoned Frame.io uploads (files stuck in status
# "created" or "uploading") once they're older than this. Frame.io doesn't
# garbage-collect these itself. Leave unset / 0 to skip. Example: "6h".
FRAMEIO_STUCK_TIMEOUT=

